# Environment Variables — NEVER COMMIT THIS FILE
# Copy this to .env and fill in your real values

# Anthropic API (if using Claude API in your tools)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Add your project-specific secrets below
# DATABASE_URL=
# SLACK_WEBHOOK_URL=

# ── Token Economy (budget-guard.sh, /q:estimate, /q:opus) ──
# All optional — scripts fall back to these defaults if unset.
Q_DAILY_BUDGET_USD=40        # daily AI budget in dollars
Q_WORKDAY_START=8            # workday start hour (0-23)
Q_WORKDAY_END=20             # workday end hour (0-23)
Q_INPUT_PRICE_PER_M=3        # input price per 1M tokens (Bedrock Sonnet 4.6)
Q_OUTPUT_PRICE_PER_M=15      # output price per 1M tokens (Bedrock Sonnet 4.6)
# Model-tier IDs for /q:opus — see context/model-tiers.md for the routing policy.
# Gateway-specific names; fill in your gateway's IDs. Available here: sonnet 4.6,
# gpt 5.2, gpt 4.1, gpt 4.1 mini, haiku. /q:opus falls back to these defaults if unset.
# Q_MODEL_THINK=sonnet-4.6   # plan / review / verify / architecture (strongest; or gpt 5.2)
# Q_MODEL_BUILD=sonnet-4.6   # execute well-specified tasks (or gpt 4.1 for bulk)
# Q_MODEL_GRUNT=haiku        # mechanical: renames, boilerplate, docs (or gpt 4.1 mini)
